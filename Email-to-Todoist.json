        "jsCode": "const NAMES = {\n  '6gc2qFxj6vPvH52F': 'Inbox',\n  '6gchGJVQMH4f8rJc': 'Project 1',\n  '6gchGJRm92r52mPM': 'Project 2',\n  '6gchGJVJRfRww5H7': 'Project 3',\n  '6gf7GpRPFr369wQG': 'Personal',\n  '6gf7RXX4wrjQ7QhV': 'Project 4',\n  '6gchGJWrHRGPGvQr': 'Project 5',\n  '6gchGJc3MhCRHxG6': 'Project 6',\n  '6gchGJf56F4wpgwv': 'Project 7',\n  '6gchGJggMVjXCMCP': 'Project 8',\n  '6gchGJhP5wFj8Qf7': 'Project 9',\n  '6gchGJmh7x2jMXqF': 'Project 10',\n  '6gchGJmcWJJXRGq3': 'Project 11',\n  '6gchGJpVXvhC6PQj': 'Project 12',\n  '6gchGJrFMcw3p62X': 'Project 13',\n  '6gchGJqG53crVcq9': 'Project 14',\n  '6gchGJxpQfFggGf4': 'Project 15',\n  '6gchGJxGwpvjJg4j': 'Project 16',\n  '6gchGJwXW59gCrvH': 'Project 17',\n  '6gchGM3GvVwfv5vg': 'Project 18',\n  '6gchGM2jrMF64gcv': 'Project 19',\n  '6gchMG43F63QWxqp': 'New project ideas',\n  '6ggpg3pWrVxX4gqX': 'Project 20',\n};\n\nconst openTasks = [];\ntry {\n  for (const item of $input.all()) {\n    const j = item.json || {};\n    const desc = (j.description || '').toString();\n    // only tasks this pipeline created (description carries the source-email line)\n    if (!desc.includes('From:') || !desc.includes('| Account:')) continue;\n    if (j.is_completed || j.checked) continue;\n    openTasks.push({\n      title: (j.content || '').toString().slice(0, 120),\n      project: NAMES[j.project_id] || 'Unknown',\n      createdAt: (j.created_at || j.added_at || '').toString().slice(0, 10),\n    });\n    if (openTasks.length >= 300) break;\n  }\n} catch (e) {}\n\nreturn [{ json: { openTasks } }];"
      },
