      "id": "1bc7cd0f-cf88-4b27-a478-806beb3247a1",
      "name": "Merge"
    },
    {
      "parameters": {
        "jsCode": "const ZW = /[​‌‍‎‏﻿­͏⠀]/g;\n\nconst decodeEntities = s => (s || '')\n  .replace(/&zwnj;|&zwj;|&shy;/gi, '')\n  .replace(/&nbsp;/gi, ' ').replace(/&amp;/gi, '&').replace(/&lt;/gi, '<').replace(/&gt;/gi, '>')\n  .replace(/&quot;/gi, '\"').replace(/&#0*39;/g, \"'\").replace(/&#(\\d+);/g, (m, n) => { try { return String.fromCodePoint(+n); } catch (e) { return ' '; } });\n\nconst cleanText = s => decodeEntities((s || '').toString()).replace(ZW, '').replace(/\\s+/g, ' ').trim();\n\nconst stripHtml = html => cleanText((html || '')\n  .replace(/<style[\\s\\S]*?<\\/style>/gi, ' ')\n  .replace(/<script[\\s\\S]*?<\\/script>/gi, ' ')\n  .replace(/<head[\\s\\S]*?<\\/head>/gi, ' ')\n  .replace(/<[^>]+>/g, ' '));\n\nconst BAD_LINK = /unsubscribe|list-manage|email.?preferences|opt[-_]?out|privacy|view.?in.?browser|manage.?subscri|update.?preferences|mailto:/i;\n\nconst extractLinks = (html) => {\n  const links = [];\n  const seen = new Set();\n  if (!html) return links;\n  const re = /<a\\b[^>]*href=[\"']?(https?:\\/\\/[^\"'\\s>]+)[\"']?[^>]*>([\\s\\S]*?)<\\/a>/gi;\n  let m;\n  while ((m = re.exec(html)) !== null && links.length < 5) {\n    const url = m[1].slice(0, 400);\n    const label = stripHtml(m[2]).slice(0, 60);\n    if (!label) continue;\n    if (BAD_LINK.test(url) || BAD_LINK.test(label)) continue;\n    const key = url.split('?')[0];\n    if (seen.has(key)) continue;\n    seen.add(key);\n    links.push({ label, url });\n  }\n  return links;\n};\n\nconst out = [];\nfor (const item of $input.all()) {\n  const j = item.json;\n  const isGmail = j.threadId !== undefined || j.labelIds !== undefined || j.labels !== undefined || j.internalDate !== undefined;\n  const id = (j.id !== undefined && j.id !== null) ? String(j.id) : '';\n  if (isGmail) {\n    const html = j.html || '';\n    const text = cleanText(j.text) || stripHtml(html) || cleanText(j.snippet);\n    out.push({\n      messageId: id ? `gmail:${id}` : '',\n      account: j.account || '',\n      source: 'Gmail',\n      from: (j.from && (j.from.text || (j.from.value && j.from.value[0] && j.from.value[0].address))) || j.From || '',\n      subject: j.subject || j.Subject || '',\n      snippet: cleanText(j.snippet) || text.slice(0, 200),\n      bodyText: text.slice(0, 1500),\n      links: extractLinks(html),\n      date: j.date ? new Date(j.date).toISOString() : (j.internalDate ? new Date(Number(j.internalDate)).toISOString() : '')\n    });\n  } else {\n    const isHtmlBody = j.body && /html/i.test(j.body.contentType || '');\n    const html = isHtmlBody ? (j.body.content || '') : '';\n    const text = (!isHtmlBody && j.body && j.body.content) ? cleanText(j.body.content) : (stripHtml(html) || cleanText(j.bodyPreview));\n    out.push({\n      messageId: id ? `outlook:${id}` : '',\n      account: j.account || (Array.isArray(j.to) ? j.to[0]?.address : '') || '',\n      source: 'Outlook',\n      from: (typeof j.from === 'string' ? j.from : j.from?.emailAddress?.address) || '',\n      subject: j.subject || '',\n      snippet: cleanText(j.bodyPreview) || text.slice(0, 200),\n      bodyText: text.slice(0, 1500),\n      links: extractLinks(html),\n      date: j.receivedDateTime || j.sentDateTime || ''\n    });\n  }\n}\n\n// content key: sender email + normalized subject. Ignores which mailbox/provider\n// received it, so the same message landing in multiple accounts collapses to one.\nconst emailOf = s => {\n  const m = (s || '').toString().toLowerCase().match(/<([^>]+)>/);\n  return (m ? m[1] : (s || '')).toString().trim().toLowerCase();\n};\nconst normSubj = s => (s || '').toString().trim().toLowerCase()\n  .replace(/^(re|fwd|fw)\\s*:\\s*/i, '')\n  .replace(/^(re|fwd|fw)\\s*:\\s*/i, '')\n  .replace(/\\s+/g, ' ');\nfor (const m of out) {\n  m.contentKey = emailOf(m.from) + '|' + normSubj(m.subject);\n}\n\n// newest first, so the copy we keep is the freshest\nout.sort((a, b) => new Date(b.date) - new Date(a.date));\n\n// de-dupe within this run by content (collapses same message across mailboxes)\nconst seen = new Set();\nconst deduped = [];\nfor (const m of out) {\n  const key = m.contentKey || m.messageId;\n  if (seen.has(key)) continue;\n  seen.add(key);\n  deduped.push(m);\n}\n\nreturn [{ json: {\n  count: deduped.length,\n  duplicatesRemoved: out.length - deduped.length,\n  generatedAt: new Date().toISOString(),\n  messages: deduped\n} }];"
      },
