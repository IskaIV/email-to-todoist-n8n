    {
      "parameters": {
        "jsCode": "const body = $('Commit Webhook').first().json.body || {};\nlet created = [];\nlet failed = [];\ntry { created = $('Task Ack Fields').all().map(i => i.json); } catch (e) {}\ntry { failed = $('Failed Fields').all().map(i => i.json); } catch (e) {}\nconst skipped = Array.isArray(body.skipped) ? body.skipped.length : 0;\nconst received = (typeof body.received === 'number') ? body.received : created.length + failed.length + skipped;\n\nconst dateStr = new Date().toLocaleDateString('en-US', { month: 'short', day: 'numeric', timeZone: 'America/New_York' });\n\nconst lines = [];\nlines.push(`\\u{1F4E5} Email → Todoist · ${dateStr}`);\nlines.push(`Received ${received} · Created ${created.length} · Skipped ${skipped}${failed.length ? ` · Failed ${failed.length}` : ''}`);\n\nif (created.length) {\n  lines.push('');\n  lines.push('\\u{1F195} New tasks');\n  const byProj = {};\n  for (const c of created) {\n    const p = c.projectName || 'Inbox';\n    (byProj[p] = byProj[p] || []).push(c.title);\n  }\n  for (const [proj, titles] of Object.entries(byProj)) {\n    lines.push('');\n    lines.push(proj);\n    for (const t of titles) lines.push(`• ${t}`);\n  }\n} else {\n  lines.push('');\n  lines.push('No action items today — everything was noise.');\n}\n\nif (failed.length) {\n  lines.push('');\n  lines.push('⚠️ Failed (left unacked, will retry next run)');\n  for (const f of failed) lines.push(`• ${f.title}`);\n}\n\nreturn [{ json: { text: lines.join('\\n') } }];"
      },
