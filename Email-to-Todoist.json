    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || {};\nconst tasks = Array.isArray(body.tasks) ? body.tasks : [];\n\nconst PROJECTS = {\n  'inbox': '6gc2qFxj6vPvH52F',\n  'accounts payable': '6h67V5cGVfPMjjVc',\n  'awl phase enterprises': '6gchGJVQMH4f8rJc',\n  'adjusted intelligence': '6gchGJRm92r52mPM',\n  'buy my house now fast': '6gchGJVJRfRww5H7',\n  'chris personal': '6gf7GpRPFr369wQG',\n  'elev8d global llc - general business activities': '6gf7RXX4wrjQ7QhV',\n  'elev8d cannabis - general': '6gchGJWrHRGPGvQr',\n  'elev8d e-commerce': '6gchGJc3MhCRHxG6',\n  'elev8d stores': '6gchGJf56F4wpgwv',\n  'elev8d & candy brands': '6gchGJggMVjXCMCP',\n  'm1 capital fund': '6gchGJhP5wFj8Qf7',\n  'elev8d real estate development': '6gchGJmh7x2jMXqF',\n  'cancun capital fund': '6gchGJmcWJJXRGq3',\n  'elev8d theme park': '6gchGJpVXvhC6PQj',\n  'elev8d ai': '6gchGJrFMcw3p62X',\n  'trading room': '6gchGJqG53crVcq9',\n  'elev8d products': '6gchGJxpQfFggGf4',\n  'elev8d tek labs': '6gchGJxGwpvjJg4j',\n  'marketing & growth': '6gchGJwXW59gCrvH',\n  'finance & corporate': '6gchGM3GvVwfv5vg',\n  'elev8d content calendar': '6gchGM2jrMF64gcv',\n  'chris new projects ideas': '6gchMG43F63QWxqp',\n  '750 harrison': '6ggpg3pWrVxX4gqX',\n};\n\nconst norm = s => (s || '').toString()\n  .replace(/[\\u{1F300}-\\u{1FAFF}\\u{2600}-\\u{27BF}\\u{FE0F}]/gu, '')\n  .replace(/[´’‘']/g, '')\n  .toLowerCase().replace(/\\s+/g, ' ').trim();\n\nconst resolveProject = (name) => {\n  const n = norm(name);\n  if (n && PROJECTS[n]) return { id: PROJECTS[n], name: name };\n  if (n) {\n    for (const [k, id] of Object.entries(PROJECTS)) {\n      if (k.includes(n) || n.includes(k)) return { id, name: name };\n    }\n  }\n  return { id: PROJECTS['inbox'], name: 'Inbox' };\n};\n\nconst PRIO = { p1: 4, p2: 3, p3: 2, p4: 1 };\n\nconst out = [];\nfor (const t of tasks) {\n  const proj = resolveProject(t.project);\n  out.push({ json: {\n    title: (t.title || 'Untitled task').toString().slice(0, 500),\n    description: (t.description || '').toString().slice(0, 16000),\n    prio: PRIO[(t.priority || 'p4').toString().toLowerCase()] || 1,\n    dueString: t.dueString ? t.dueString.toString() : '',\n    projectName: proj.name,\n    projectId: proj.id,\n    messageId: t.messageId || '',\n    subject: t.subject || '',\n    contentKey: t.contentKey || '',\n  }});\n}\nreturn out;"
      },
